spring:
  application:
    name: moyelog_BE
  
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 10MB
  
  datasource:
    url: jdbc:mysql://localhost:3306/moyeolog?serverTimezone=Asia/Seoul&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: your_password_here
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

jwt:
  secret: your_jwt_secret_here
  expiration: 86400000 # 24 hours

gemini:
  api:
    key: ${GEMINI_API_KEY:your_gemini_api_key_here}

server:
  tomcat:
    max-http-post-size: 10MB
